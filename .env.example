# ══════════════════════════════════════════
# .env — 環境変数テンプレート
# このファイルを .env にリネームして使用してください
# .env は .gitignore に追加済みです（APIキーを絶対にGitにコミットしないこと）
# ══════════════════════════════════════════

# ── Step 1: 必須 ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-ここにキーを貼り付け

# ── Step 3: 画像生成（どちらか一方でOK）──
STABILITY_API_KEY=sk-ここにキーを貼り付け
OPENAI_API_KEY=sk-ここにキーを貼り付け

# ── Step 4: SNS投稿 ───────────────────────
# X (Twitter)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Instagram / Meta Graph API
META_ACCESS_TOKEN=
META_INSTAGRAM_ACCOUNT_ID=

# Buffer (複数SNS一元管理)
BUFFER_ACCESS_TOKEN=

# ── Step 5: DB (Supabase) ─────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=
